@page "/"
@implements IAsyncDisposable
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<BookstoreDb> DbContextFactory
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Bookstore -  Home</PageTitle>

<div class="row mt-5 mx-auto">
    <div class="col-sm-2 border pt-3 me-3 mb-3">
        <a href="/books/create" class="btn btn-primary">Create New</a>
        <div class="mt-3">
            <input class="form-control text-muted" placeholder="Search..." value="@SearchFilter" @oninput="OnSearchChanged" />
        </div>


        <div class="mt-3">
            <h6> Filter by: </h6>
            <select class="form-select" value="@GenreFilter" @onchange="OnGenreChanged">
                <option value="">Genre</option>
                @if (genres != null)
                {
                    foreach (var genre in genres)
                    {
                        <option value="@genre">@genre</option>
                    }
                }
            </select>
            </div>
            <div class="mt-3">
                <h6> Sort by: </h6>
                <select class="form-select" value="@SortPrice" @onchange="OnSortChanged">
                    <option value="">Price</option>
                    <option value="asc">Lowest Price</option>
                    <option value="desc">Highest Price</option>
                </select>
            </div>
    </div>
    <div class="col">
        @if (books is null)
        {
            <p>Loading...</p>
        } else {
            <div class="hstack flex-wrap gap-3">
                @foreach (var book in paged) {
                    <BookCard Book="@book" />
                }
            </div>
            <nav class="mt-3">
                <ul class="pagination">
                    <li class="page-item @(Page == 1 ? "disabled" : "")">
                        <button class="page-link" @onclick="() => GoToPage(Page - 1)">&laquo;</button>
                    </li>
                    @for (int i = 1; i <= totalPages; i++)
                    {
                        var p = i;
                        <li class="page-item @(Page == p ? "active" : "")">
                            <button class="page-link" @onclick="() => GoToPage(p)">@p</button>
                        </li>
                    }
                    <li class="page-item @(Page == totalPages ? "disabled" : "")">
                        <button class="page-link" @onclick="() => GoToPage(Page + 1)">&raquo;</button>
                    </li>
                </ul>
            </nav>
        }
    </div>
</div>


@code {
    private BookstoreDb context {get; set; }

    private IEnumerable<Book> books => context.Books.AsNoTracking();

    [SupplyParameterFromQuery(Name = "search")]
    public string? SearchFilter { get; set; }

    [SupplyParameterFromQuery(Name = "genre")]
    public string? GenreFilter { get; set; }

    [SupplyParameterFromQuery(Name = "sort")]
    public string? SortPrice { get; set; }

    [SupplyParameterFromQuery(Name = "page")]
    public int? CurrentPage { get; set; }

    private int Page => CurrentPage is null or < 1 ? 1 : CurrentPage.Value;

    private IEnumerable<Book> filtered => books
        .Where(b => string.IsNullOrWhiteSpace(SearchFilter)
            || b.Title.Contains(SearchFilter, StringComparison.OrdinalIgnoreCase)
            || b.Author.Contains(SearchFilter, StringComparison.OrdinalIgnoreCase))
        .Where(b => string.IsNullOrWhiteSpace(GenreFilter) || b.Genre == GenreFilter);

    private IEnumerable<Book> sorted => SortPrice switch
    {
        "asc" => filtered.OrderBy(b => b.Price),
        "desc" => filtered.OrderByDescending(b => b.Price),
        _ => filtered
    };

    private int pageSize = 3;
    private int totalPages => Math.Max(1, (int)Math.Ceiling((double)sorted.Count() / pageSize));
    private IEnumerable<Book> paged => sorted.Skip((Page - 1) * pageSize).Take(pageSize);

    private IEnumerable<string> genres => books.Select(b => b.Genre).Distinct();

    protected override void OnInitialized()
    {
        context = DbContextFactory.CreateDbContext();
    }

    private void OnSearchChanged(ChangeEventArgs e)
    {
        NavigationManager.NavigateTo(BuildUrl(search: e.Value?.ToString() ?? string.Empty, page: 1), replace: true);
    }

    private void OnGenreChanged(ChangeEventArgs e)
    {
        NavigationManager.NavigateTo(BuildUrl(genre: e.Value?.ToString() ?? string.Empty, page: 1), replace: true);
    }

    private void OnSortChanged(ChangeEventArgs e)
    {
        NavigationManager.NavigateTo(BuildUrl(sort: e.Value?.ToString() ?? string.Empty, page: 1), replace: true);
    }

    private void GoToPage(int page)
    {
        if (page < 1 || page > totalPages) return;
        NavigationManager.NavigateTo(BuildUrl(page: page), replace: true);
    }

    private string BuildUrl(string? search = null, string? genre = null, string? sort = null, int? page = null)
    {
        var s = search ?? SearchFilter ?? string.Empty;
        var g = genre ?? GenreFilter ?? string.Empty;
        var so = sort ?? SortPrice ?? string.Empty;
        var p = page ?? Page;

        var parts = new List<string>();
        if (!string.IsNullOrWhiteSpace(s)) parts.Add($"search={Uri.EscapeDataString(s)}");
        if (!string.IsNullOrWhiteSpace(g)) parts.Add($"genre={Uri.EscapeDataString(g)}");
        if (!string.IsNullOrWhiteSpace(so)) parts.Add($"sort={Uri.EscapeDataString(so)}");
        if (p > 1) parts.Add($"page={p}");

        return parts.Count == 0 ? "/" : "/?" + string.Join("&", parts);
    }

    public async ValueTask DisposeAsync()
    {
        if (context is not null)
        {
            await context.DisposeAsync();
        }
    }
}
